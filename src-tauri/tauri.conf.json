{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "openix-widgets",
  "version": "0.1.0",
  "identifier": "com.yuzukitsuru.openix-widgets",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OpenixWidgets",
        "width": 1280,
        "height": 880,
        "minWidth": 1090,
        "minHeight": 880,
        "center": true,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
